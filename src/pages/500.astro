---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
---

<Layout
  title="Server Error"
  description="Something went wrong on our end. Please try again."
  canonical="https://main.expensy-31c.pages.dev//500/"
>
  <Header />
  <main class="mx-auto flex min-h-[60vh] max-w-2xl flex-col items-center justify-center px-6 pt-32 pb-24 text-center">
    <span class="font-bradford text-8xl font-medium text-white/10">500</span>
    <h1 class="-mt-4 font-bradford text-3xl font-medium text-cloud-whisper sm:text-4xl">
      Server Error
    </h1>
    <p class="mt-3 font-visueltpro leading-relaxed text-mist-gray">
      Something broke on our end. Give it another try — your data stays in your browser, so nothing was lost.
    </p>
    <a
      href="/"
      class="mt-8 inline-flex items-center justify-center rounded-full bg-slate-dust px-8 py-3 font-visueltpro text-sm font-medium text-midnight-void transition-all hover:bg-white"
    >
      Back to the Analyzer
    </a>
  </main>
  <Footer />
</Layout>
