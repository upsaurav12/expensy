---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
---

<Layout
  title="Contact Us — expensy Money Leak Detector"
  description="Get in touch with the expensy team. Have feedback, questions, or suggestions about our Money Leak Detector? We'd love to hear from you."
  canonical="https://main.expensy-31c.pages.dev//contact/"
>
  <Header />
  <main class="mx-auto max-w-3xl px-6 pt-32 pb-24">
    <div class="mb-6 inline-flex items-center gap-2 rounded-full border border-white/10 bg-white/5 px-4 py-1.5">
      <span class="font-visueltpro text-xs tracking-wide text-mist-gray">Contact</span>
    </div>

    <h1 class="font-bradford text-4xl font-medium leading-tight tracking-tight text-cloud-whisper sm:text-5xl">
      Contact Us
    </h1>
    <p class="mt-4 font-visueltpro text-lg leading-relaxed text-mist-gray">
      Have feedback, suggestions, or questions? We'd love to hear from you.
    </p>

    <hr class="my-10 border-white/10" />

    <div class="rounded-xl border border-white/10 bg-white/[0.02] p-8">
      <form
        action="https://formsubmit.co/hello@expensy.com"
        method="POST"
        class="space-y-6"
      >
        <input type="hidden" name="_subject" value="expensy Contact Form" />
        <input type="hidden" name="_captcha" value="true" />
        <input type="hidden" name="_template" value="table" />
        <input type="text" name="_honey" class="hidden" />

        <div>
          <label for="name" class="mb-2 block font-visueltpro text-sm font-medium text-cloud-whisper">
            Name
          </label>
          <input
            type="text"
            id="name"
            name="name"
            required
            placeholder="Your name"
            class="w-full rounded-xl border border-white/10 bg-midnight-void px-4 py-3 font-visueltpro text-sm text-cloud-whisper placeholder-ash-accent/50 outline-none transition-colors focus:border-white/30"
          />
        </div>

        <div>
          <label for="email" class="mb-2 block font-visueltpro text-sm font-medium text-cloud-whisper">
            Email
          </label>
          <input
            type="email"
            id="email"
            name="email"
            required
            placeholder="you@example.com"
            class="w-full rounded-xl border border-white/10 bg-midnight-void px-4 py-3 font-visueltpro text-sm text-cloud-whisper placeholder-ash-accent/50 outline-none transition-colors focus:border-white/30"
          />
        </div>

        <div>
          <label for="message" class="mb-2 block font-visueltpro text-sm font-medium text-cloud-whisper">
            Message
          </label>
          <textarea
            id="message"
            name="message"
            required
            rows="5"
            placeholder="Tell us what's on your mind..."
            class="w-full rounded-xl border border-white/10 bg-midnight-void px-4 py-3 font-visueltpro text-sm text-cloud-whisper placeholder-ash-accent/50 outline-none transition-colors focus:border-white/30"
          ></textarea>
        </div>

        <button
          type="submit"
          class="inline-flex w-full items-center justify-center rounded-full bg-slate-dust px-8 py-3.5 font-visueltpro text-sm font-medium text-midnight-void shadow-lg transition-all hover:bg-white active:scale-[0.98]"
        >
          Send Message
        </button>
      </form>
    </div>

    <div class="mt-10">
      <h2 class="font-bradford text-2xl font-medium text-cloud-whisper">Other Ways to Reach Us</h2>
      <p class="mt-3 font-visueltpro leading-relaxed text-mist-gray">
        Prefer email? Write to us directly at <a href="mailto:hello@expensy.com" class="text-cloud-whisper underline underline-offset-2 decoration-white/20 hover:decoration-white/60">hello@expensy.com</a>.
      </p>
      <p class="mt-3 font-visueltpro leading-relaxed text-mist-gray">
        Your privacy matters. We never share your information with third parties.
      </p>
    </div>
  </main>
  <Footer />
</Layout>
