---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
---

<Layout
  title="Page Not Found"
  description="The page you're looking for doesn't exist. Return to the Money Leak Detector homepage."
  canonical="https://main.expensy-31c.pages.dev//404/"
>
  <Header />
  <main class="mx-auto flex min-h-[60vh] max-w-2xl flex-col items-center justify-center px-6 pt-32 pb-24 text-center">
    <span class="font-bradford text-8xl font-medium text-white/10">404</span>
    <h1 class="-mt-4 font-bradford text-3xl font-medium text-cloud-whisper sm:text-4xl">
      Page Not Found
    </h1>
    <p class="mt-3 font-visueltpro leading-relaxed text-mist-gray">
      This page doesn't exist — or your money is hiding so well even we can't find it.
    </p>
    <a
      href="/"
      class="mt-8 inline-flex items-center justify-center rounded-full bg-slate-dust px-8 py-3 font-visueltpro text-sm font-medium text-midnight-void transition-all hover:bg-white"
    >
      Back to the Analyzer
    </a>
  </main>
  <Footer />
</Layout>
