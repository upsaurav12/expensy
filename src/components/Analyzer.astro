---

const expenseFields = [
  { id: "housing", label: "Housing", sublabel: "Rent / Mortgage", placeholder: "e.g. 15000", group: "fixed" },
  { id: "food", label: "Food", sublabel: "Groceries + Dining", placeholder: "e.g. 8000", group: "variable" },
  { id: "transportation", label: "Transportation", sublabel: "Fuel / Public Transport", placeholder: "e.g. 3000", group: "variable" },
  { id: "shopping", label: "Shopping", sublabel: "Clothes / Gadgets / Misc", placeholder: "e.g. 5000", group: "variable" },
  { id: "entertainment", label: "Entertainment", sublabel: "Movies / Gaming / Leisure", placeholder: "e.g. 2000", group: "variable" },
  { id: "subscriptions", label: "Subscriptions", sublabel: "Netflix / Spotify / Apps", placeholder: "e.g. 1500", group: "fixed" },
  { id: "utilities", label: "Utilities", sublabel: "Electricity / Water / Internet", placeholder: "e.g. 3000", group: "semi-variable" },
  { id: "other", label: "Other", sublabel: "Catch-all category", placeholder: "e.g. 2000", group: "semi-variable" },
];
---

<section id="analyzer" class="mx-auto max-w-6xl px-6 pb-32">
  <!-- Form -->
  <div id="form-section" class="mx-auto max-w-2xl">
    <div class="mb-10 text-center">
      <h2 class="font-bradford text-3xl font-medium text-cloud-whisper sm:text-4xl">
        Where's your money going?
      </h2>
      <p class="mt-3 font-visueltpro text-mist-gray">
        Enter your monthly numbers. We'll find the leaks.
      </p>
    </div>

    <div class="rounded-xl border border-white/10 bg-white/[0.02] p-8">
      <!-- Income -->
      <div class="mb-8">
        <label for="income" class="mb-2 block font-visueltpro text-sm font-medium text-cloud-whisper">
          Monthly Income
        </label>
        <div class="relative">
          <span class="absolute left-4 top-1/2 -translate-y-1/2 font-visueltpro text-sm text-ash-accent">&#x20B9;</span>
          <input
            type="number"
            id="income"
            min="0"
            step="1000"
            placeholder="e.g. 50000"
            class="w-full rounded-xl border border-white/10 bg-midnight-void px-8 py-3.5 pl-8 font-visueltpro text-sm text-cloud-whisper placeholder-ash-accent/50 outline-none transition-colors focus:border-white/30"
          />
        </div>
      </div>

      <!-- Expenses -->
      <div class="mb-2">
        <h3 class="mb-1 font-visueltpro text-xs font-medium uppercase tracking-widest text-ash-accent">
          Monthly Expenses
        </h3>
        <p class="mb-6 font-visueltpro text-xs text-ash-accent">All fields are in &#x20B9; (Indian Rupees)</p>
      </div>

      <div class="grid gap-5 sm:grid-cols-2">
        {expenseFields.map((field) => (
          <div key={field.id}>
            <label for={field.id} class="mb-1 block font-visueltpro text-sm text-cloud-whisper">
              {field.label}
              <span class="text-ash-accent"> &middot; {field.sublabel}</span>
            </label>
            <div class="relative">
              <span class="absolute left-3.5 top-1/2 -translate-y-1/2 font-visueltpro text-xs text-ash-accent">&#x20B9;</span>
              <input
                type="number"
                id={field.id}
                min="0"
                step="100"
                placeholder={field.placeholder}
                class="w-full rounded-lg border border-white/10 bg-midnight-void px-7 py-2.5 pl-7 font-visueltpro text-sm text-cloud-whisper placeholder-ash-accent/50 outline-none transition-colors focus:border-white/30"
                data-group={field.group}
              />
            </div>
          </div>
        ))}
      </div>

      <button
        id="analyze-btn"
        class="mt-8 inline-flex w-full items-center justify-center rounded-full bg-slate-dust px-8 py-3.5 font-visueltpro text-sm font-medium text-midnight-void shadow-lg transition-all hover:bg-white active:scale-[0.98]"
      >
        Find My Money Leaks
      </button>
    </div>
  </div>

  <!-- Results Dashboard -->
  <div id="results-section" class="hidden mx-auto max-w-5xl">
    <div class="mb-10 text-center">
      <h2 class="font-bradford text-3xl font-medium text-cloud-whisper sm:text-4xl">
        Your Financial Report
      </h2>
      <p class="mt-3 font-visueltpro text-mist-gray">
        Personalized analysis based on your spending.
      </p>
    </div>

    <!-- Health Score -->
    <div class="mb-8 rounded-xl border border-white/10 bg-white/[0.02] p-8 text-center">
      <p class="mb-2 font-visueltpro text-xs font-medium uppercase tracking-widest text-ash-accent">
        Financial Health Score
      </p>
      <div class="flex items-baseline justify-center gap-3">
        <span id="health-score" class="font-bradford text-7xl text-cloud-whisper">--</span>
        <span id="health-label" class="rounded-full border border-white/10 bg-white/5 px-4 py-1 font-visueltpro text-sm">
          --
        </span>
      </div>
    </div>

    <!-- Summary Cards -->
    <div class="mb-8 grid gap-4 sm:grid-cols-4">
      <div class="rounded-xl border border-white/10 bg-white/[0.02] p-5">
        <p class="mb-1 font-visueltpro text-xs font-medium uppercase tracking-widest text-ash-accent">Income</p>
        <p id="total-income" class="font-bradford text-2xl text-cloud-whisper">&#x20B9;0</p>
      </div>
      <div class="rounded-xl border border-white/10 bg-white/[0.02] p-5">
        <p class="mb-1 font-visueltpro text-xs font-medium uppercase tracking-widest text-ash-accent">Expenses</p>
        <p id="total-expenses" class="font-bradford text-2xl text-cloud-whisper">&#x20B9;0</p>
      </div>
      <div class="rounded-xl border border-white/10 bg-white/[0.02] p-5">
        <p class="mb-1 font-visueltpro text-xs font-medium uppercase tracking-widest text-ash-accent">Remaining</p>
        <p id="remaining-balance" class="font-bradford text-2xl text-cloud-whisper">&#x20B9;0</p>
      </div>
      <div class="rounded-xl border border-white/10 bg-white/[0.02] p-5">
        <p class="mb-1 font-visueltpro text-xs font-medium uppercase tracking-widest text-ash-accent">Savings Rate</p>
        <p id="savings-rate" class="font-bradford text-2xl text-cloud-whisper">0%</p>
      </div>
    </div>

    <!-- Biggest Money Leaks -->
    <div class="mb-8 rounded-xl border border-white/10 bg-white/[0.02] p-8">
      <h3 class="mb-1 font-visueltpro text-xs font-medium uppercase tracking-widest text-ash-accent">
        Biggest Money Leaks
      </h3>
      <p class="mb-6 font-visueltpro text-xs text-ash-accent">Categories where you're spending more than recommended.</p>
      <div id="leaks-container" class="space-y-4">
        <p class="font-visueltpro text-sm text-mist-gray">Submit your expenses to detect leaks.</p>
      </div>
    </div>

    <!-- Potential Savings -->
    <div class="mb-8 grid gap-4 sm:grid-cols-2">
      <div class="rounded-xl border border-white/10 bg-white/[0.02] p-6">
        <p class="mb-1 font-visueltpro text-xs font-medium uppercase tracking-widest text-ash-accent">
          Potential Monthly Savings
        </p>
        <p id="savings-monthly" class="font-bradford text-3xl text-cloud-whisper">&#x20B9;0</p>
      </div>
      <div class="rounded-xl border border-white/10 bg-white/[0.02] p-6">
        <p class="mb-1 font-visueltpro text-xs font-medium uppercase tracking-widest text-ash-accent">
          Potential Annual Savings
        </p>
        <p id="savings-annual" class="font-bradford text-3xl text-cloud-whisper">&#x20B9;0</p>
      </div>
    </div>

    <!-- Expense Breakdown -->
    <div class="mb-8 rounded-xl border border-white/10 bg-white/[0.02] p-8">
      <h3 class="mb-1 font-visueltpro text-xs font-medium uppercase tracking-widest text-ash-accent">
        Expense Breakdown
      </h3>
      <p class="mb-6 font-visueltpro text-xs text-ash-accent">How your income is allocated across categories.</p>

      <div class="mb-6 space-y-4">
        {expenseFields.map((field) => (
          <div key={field.id}>
            <div class="mb-1.5 flex items-center justify-between">
              <span class="font-visueltpro text-sm text-mist-gray">{field.label}</span>
              <span class="font-visueltpro text-sm text-cloud-whisper">
                <span id={`${field.id}-amount`}>&#x20B9;0</span>
                <span id={`${field.id}-percent`} class="text-ash-accent"> (0%)</span>
              </span>
            </div>
            <div class="h-2 overflow-hidden rounded-full bg-white/5">
              <div id={`${field.id}-bar`} class="h-full w-0 rounded-full transition-all duration-700"
                style="background-color: var(--bar-color, #c0c0c0)"
              ></div>
            </div>
          </div>
        ))}
      </div>

      <!-- Fixed Expense Risk -->
      <div class="mt-8 border-t border-white/10 pt-6">
        <div class="flex items-center justify-between">
          <span class="font-visueltpro text-sm text-cloud-whisper">Fixed Expense Ratio</span>
          <span id="fixed-risk-label" class="rounded-full border border-white/10 bg-white/5 px-3 py-0.5 font-visueltpro text-xs">--</span>
        </div>
        <p id="fixed-risk-detail" class="mt-1 font-visueltpro text-xs text-ash-accent">
          Fixed expenses (Housing + Subscriptions) as a percentage of income.
        </p>
      </div>
    </div>

    <!-- Action Plan -->
    <div class="rounded-xl border border-white/10 bg-white/[0.02] p-8">
      <h3 class="mb-1 font-visueltpro text-xs font-medium uppercase tracking-widest text-ash-accent">
        Action Plan
      </h3>
      <p class="mb-6 font-visueltpro text-xs text-ash-accent">3 personalized recommendations to plug your money leaks.</p>
      <ol id="action-plan" class="space-y-4 list-none">
        <li class="font-visueltpro text-sm text-mist-gray">Submit your expenses to see your action plan.</li>
      </ol>
    </div>

    <!-- Reset -->
    <div class="mt-8 text-center">
      <button
        id="reset-btn"
        class="inline-flex items-center gap-2 rounded-full border border-white/20 px-6 py-2.5 font-visueltpro text-sm text-mist-gray transition-colors hover:border-white/40 hover:text-cloud-whisper"
      >
        Analyze Again
      </button>
    </div>
  </div>
</section>

<script>
  // Category config
  const CATEGORIES = [
    { id: "housing", label: "Housing", group: "fixed", threshold: 40, color: "#60a5fa" },
    { id: "food", label: "Food", group: "variable", threshold: 25, color: "#f59e0b" },
    { id: "transportation", label: "Transportation", group: "variable", threshold: 15, color: "#a78bfa" },
    { id: "shopping", label: "Shopping", group: "variable", threshold: 15, color: "#f472b6" },
    { id: "entertainment", label: "Entertainment", group: "variable", threshold: 10, color: "#34d399" },
    { id: "subscriptions", label: "Subscriptions", group: "fixed", threshold: 5, color: "#f87171" },
    { id: "utilities", label: "Utilities", group: "semi-variable", threshold: 10, color: "#38bdf8" },
    { id: "other", label: "Other", group: "semi-variable", threshold: 10, color: "#e2e8f0" },
  ];

  const FIXED_IDS = ["housing", "subscriptions"];
  const DISCRETIONARY_IDS = ["food", "shopping", "entertainment"];

  const formSection = document.getElementById("form-section");
  const resultsSection = document.getElementById("results-section");
  const analyzeBtn = document.getElementById("analyze-btn");
  const resetBtn = document.getElementById("reset-btn");
  const incomeInput = document.getElementById("income");

  function getValue(id) {
    return parseFloat(document.getElementById(id).value) || 0;
  }

  function fmt(n) {
    return "₹" + Math.round(n).toLocaleString("en-IN");
  }

  function getPercent(part, total) {
    return total > 0 ? (part / total) * 100 : 0;
  }

  function calculateScore(savingsRate, fixedRatio, discretionaryRatio) {
    let score = 0;

    // Savings Rate (40 points)
    if (savingsRate >= 20) score += 40;
    else if (savingsRate >= 15) score += 32;
    else if (savingsRate >= 10) score += 24;
    else if (savingsRate >= 5) score += 14;
    else if (savingsRate >= 0) score += 6;
    else score -= 4; // overspending

    // Fixed Expense Ratio (25 points)
    if (fixedRatio < 30) score += 25;
    else if (fixedRatio < 40) score += 20;
    else if (fixedRatio < 50) score += 14;
    else if (fixedRatio < 60) score += 7;
    else score += 0;

    // Discretionary Spending (20 points)
    if (discretionaryRatio < 20) score += 20;
    else if (discretionaryRatio < 30) score += 15;
    else if (discretionaryRatio < 40) score += 9;
    else if (discretionaryRatio < 50) score += 4;
    else score += 0;

    // Emergency Fund Potential (15 points)
    if (savingsRate >= 20) score += 15;
    else if (savingsRate >= 15) score += 12;
    else if (savingsRate >= 10) score += 8;
    else if (savingsRate >= 5) score += 4;
    else score += 0;

    return Math.max(0, Math.min(100, Math.round(score)));
  }

  function getHealthLabel(score) {
    if (score >= 80) return { label: "Excellent", color: "text-emerald-400" };
    if (score >= 60) return { label: "Good", color: "text-blue-400" };
    if (score >= 40) return { label: "Fair", color: "text-amber-400" };
    return { label: "Poor", color: "text-red-400" };
  }

  function getFixedRiskLabel(ratio) {
    if (ratio < 40) return { label: "Healthy", color: "text-emerald-400" };
    if (ratio <= 60) return { label: "Moderate", color: "text-amber-400" };
    return { label: "Risky", color: "text-red-400" };
  }

  function getLeaks(income, values) {
    const leaks = [];
    CATEGORIES.forEach((cat) => {
      const val = values[cat.id] || 0;
      const pct = getPercent(val, income);
      if (pct > cat.threshold && val > 0) {
        leaks.push({
          id: cat.id,
          label: cat.label,
          percent: pct,
          current: val,
          ideal: Math.round((cat.threshold / 100) * income),
          overshoot: Math.round(val - (cat.threshold / 100) * income),
          threshold: cat.threshold,
          color: cat.color,
        });
      }
    });
    return leaks.sort((a, b) => b.overshoot - a.overshoot).slice(0, 3);
  }

  function getSavingsOpportunities(leaks) {
    let totalMonthly = 0;
    leaks.forEach((leak) => {
      // Recommend reducing overshoot by 20% of current spending
      const reduction = Math.round(leak.current * 0.20);
      totalMonthly += reduction;
    });
    return {
      monthly: totalMonthly,
      annual: totalMonthly * 12,
    };
  }

  function generateActionPlan(income, expenses, leaks, savingsRate, fixedRatio) {
    const plan = [];

    // Leak-based recommendations first
    leaks.forEach((leak) => {
      const reductionTarget = Math.round(leak.current * 0.20);
      if (leak.id === "food") {
        plan.push(`Reduce dining and grocery expenses by ₹${reductionTarget.toLocaleString("en-IN")}/month. Meal planning and cooking at home can make a big difference.`);
      } else if (leak.id === "shopping") {
        plan.push(`Set a shopping budget of ₹${reductionTarget.toLocaleString("en-IN")}/month. Try a 24-hour wait rule before non-essential purchases.`);
      } else if (leak.id === "subscriptions") {
        plan.push(`Review and cancel unused subscriptions. Cutting back could save ₹${reductionTarget.toLocaleString("en-IN")}/month.`);
      } else if (leak.id === "entertainment") {
        plan.push(`Look for free or lower-cost entertainment options. Reducing by ₹${reductionTarget.toLocaleString("en-IN")}/month is realistic.`);
      } else if (leak.id === "transportation") {
        plan.push(`Consider public transport or carpooling to reduce fuel costs by ₹${reductionTarget.toLocaleString("en-IN")}/month.`);
      } else if (leak.id === "housing") {
        plan.push(`Housing costs are high at ${leak.percent.toFixed(0)}% of income. Consider finding a more affordable arrangement or adding a roommate.`);
      } else if (leak.id === "utilities") {
        plan.push(`Reduce utility bills by ₹${reductionTarget.toLocaleString("en-IN")}/month. Try energy-efficient appliances and mindful usage.`);
      } else {
        plan.push(`Reduce ${leak.label.toLowerCase()} spending by ₹${reductionTarget.toLocaleString("en-IN")}/month to align with recommended budgets.`);
      }
    });

    // General recommendation if savings rate is low
    if (savingsRate < 10 && leaks.length > 0) {
      const totalPotential = leaks.reduce((sum, l) => sum + Math.round(l.current * 0.20), 0);
      if (totalPotential > 0) {
        plan.push(`By addressing these leaks, you could save approximately ₹${totalPotential.toLocaleString("en-IN")}/month (₹${(totalPotential * 12).toLocaleString("en-IN")}/year).`);
      }
    }

    // Positive reinforcement if things look good
    if (leaks.length === 0 && savingsRate >= 15) {
      plan.push("Your spending looks well-balanced. Keep up the good habits and focus on maintaining your savings rate.");
      plan.push("Consider investing your surplus savings in a diversified portfolio for long-term growth.");
    }

    if (leaks.length === 0 && savingsRate >= 5) {
      plan.push("No major leaks detected. Your spending is within recommended ranges.");
      plan.push("Try increasing your savings rate to 20% by automating transfers on payday.");
    }

    if (fixedRatio > 50) {
      plan.push(`Your fixed expenses are ${fixedRatio.toFixed(0)}% of income. Negotiate bills and consider more affordable alternatives.`);
    }

    return plan.slice(0, 3);
  }

  function analyze() {
    const income = getValue("income");
    if (income <= 0) {
      alert("Please enter your monthly income.");
      return;
    }

    // Collect values
    const values = {};
    CATEGORIES.forEach((cat) => {
      values[cat.id] = getValue(cat.id);
    });

    const totalExpenses = CATEGORIES.reduce((sum, cat) => sum + values[cat.id], 0);
    const remaining = income - totalExpenses;
    const savingsRate = getPercent(remaining, income);

    // Fixed expense ratio
    const fixedTotal = FIXED_IDS.reduce((sum, id) => sum + values[id], 0);
    const fixedRatio = getPercent(fixedTotal, income);

    // Discretionary ratio
    const discretionaryTotal = DISCRETIONARY_IDS.reduce((sum, id) => sum + values[id], 0);
    const discretionaryRatio = getPercent(discretionaryTotal, income);

    // Score
    const score = calculateScore(savingsRate, fixedRatio, discretionaryRatio);
    const health = getHealthLabel(score);

    // Leaks
    const leaks = getLeaks(income, values);

    // Savings opportunities
    const savings = getSavingsOpportunities(leaks);

    // Fixed risk
    const fixedRisk = getFixedRiskLabel(fixedRatio);

    // Action plan
    const plan = generateActionPlan(income, values, leaks, savingsRate, fixedRatio);

    // ----- Update DOM -----

    // Health score
    document.getElementById("health-score").textContent = score;
    const hl = document.getElementById("health-label");
    hl.textContent = health.label;
    hl.className = `rounded-full border border-white/10 bg-white/5 px-4 py-1 font-visueltpro text-sm ${health.color}`;

    // Summary
    document.getElementById("total-income").textContent = fmt(income);
    document.getElementById("total-expenses").textContent = fmt(totalExpenses);
    document.getElementById("remaining-balance").textContent = fmt(remaining);
    document.getElementById("savings-rate").textContent = savingsRate.toFixed(1) + "%";

    // Category bars
    CATEGORIES.forEach((cat) => {
      const val = values[cat.id];
      const pct = getPercent(val, income);
      document.getElementById(`${cat.id}-amount`).innerHTML = fmt(val);
      document.getElementById(`${cat.id}-percent`).textContent = ` (${pct.toFixed(0)}%)`;
      const bar = document.getElementById(`${cat.id}-bar`);
      bar.style.width = Math.min(pct, 100) + "%";
      bar.style.setProperty("--bar-color", cat.color);
      bar.style.backgroundColor = cat.color;
    });

    // Fixed risk
    const frLabel = document.getElementById("fixed-risk-label");
    frLabel.textContent = fixedRisk.label;
    frLabel.className = `rounded-full border border-white/10 bg-white/5 px-3 py-0.5 font-visueltpro text-xs ${fixedRisk.color}`;
    document.getElementById("fixed-risk-detail").textContent =
      `Fixed expenses are ${fixedRatio.toFixed(0)}% of income — classified as ${fixedRisk.label.toLowerCase()}.`;

    // Leaks
    const leaksContainer = document.getElementById("leaks-container");
    leaksContainer.innerHTML = "";
    if (leaks.length === 0) {
      leaksContainer.innerHTML = `
        <div class="flex items-start gap-3 rounded-lg border border-white/10 bg-emerald-500/5 p-4">
          <span class="mt-0.5 h-2 w-2 shrink-0 rounded-full bg-emerald-400"></span>
          <div>
            <p class="font-visueltpro text-sm font-medium text-emerald-400">No major leaks detected</p>
            <p class="mt-0.5 font-visueltpro text-xs text-mist-gray">Your spending is within recommended ranges across all categories.</p>
          </div>
        </div>
      `;
    } else {
      leaks.forEach((leak, i) => {
        const div = document.createElement("div");
        div.className = "flex items-start gap-3 rounded-lg border border-white/10 bg-white/[0.02] p-4";
        div.innerHTML = `
          <span class="flex h-6 w-6 shrink-0 items-center justify-center rounded-full font-visueltpro text-xs font-medium text-midnight-void"
            style="background-color: ${leak.color}">${i + 1}</span>
          <div class="flex-1 min-w-0">
            <div class="flex items-center justify-between gap-2">
              <p class="font-visueltpro text-sm font-medium text-cloud-whisper">${leak.label}</p>
              <span class="shrink-0 font-visueltpro text-xs font-medium text-red-400">${leak.percent.toFixed(0)}%</span>
            </div>
            <p class="mt-0.5 font-visueltpro text-xs text-mist-gray">
              Spending ${leak.percent.toFixed(0)}% of income — above the recommended ${leak.threshold}% threshold.
              Overspending by ${fmt(leak.overshoot)}/month.
            </p>
          </div>
        `;
        leaksContainer.appendChild(div);
      });
    }

    // Savings
    document.getElementById("savings-monthly").innerHTML = fmt(savings.monthly);
    document.getElementById("savings-annual").innerHTML = fmt(savings.annual);

    // Action plan
    const planList = document.getElementById("action-plan");
    planList.innerHTML = "";
    if (plan.length === 0) {
      planList.innerHTML = `<li class="font-visueltpro text-sm text-mist-gray">Your finances look well-managed. No specific actions needed.</li>`;
    } else {
      plan.forEach((item) => {
        const li = document.createElement("li");
        li.className = "flex items-start gap-3 font-visueltpro text-sm leading-relaxed text-mist-gray";
        li.innerHTML = `<span class="mt-1.5 flex h-5 w-5 shrink-0 items-center justify-center rounded-full bg-white/10 font-visueltpro text-xs text-cloud-whisper">${planList.children.length + 1}</span>${item}`;
        planList.appendChild(li);
      });
    }

    // Toggle views
    formSection.classList.add("hidden");
    resultsSection.classList.remove("hidden");
    resultsSection.classList.add("block");
    window.scrollTo({ top: resultsSection.offsetTop - 100, behavior: "smooth" });
  }

  function reset() {
    formSection.classList.remove("hidden");
    resultsSection.classList.add("hidden");
    resultsSection.classList.remove("block");
    window.scrollTo({ top: document.getElementById("analyzer").offsetTop - 100, behavior: "smooth" });
  }

  // Enter key navigation
  function onKeydown(e) {
    if (e.key === "Enter") {
      e.preventDefault();
      analyze();
    }
  }

  analyzeBtn.addEventListener("click", analyze);
  resetBtn.addEventListener("click", reset);
  incomeInput.addEventListener("keydown", onKeydown);
  document.querySelectorAll("#analyzer input").forEach((el) => {
    el.addEventListener("keydown", (e) => {
      if (e.key === "Enter") {
        e.preventDefault();
        const inputs = Array.from(document.querySelectorAll("#analyzer input"));
        const idx = inputs.indexOf(el);
        if (idx < inputs.length - 1) {
          inputs[idx + 1].focus();
        } else {
          analyze();
        }
      }
    });
  });
</script>
